<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="#0D0C1E"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:type="linear"
                android:startColor="#1C1A34"
                android:endColor="#08071A"
                android:angle="135"/>
            <corners android:radius="24dp"/>
            <stroke android:width="1dp" android:color="#FFFFFF14"/>
        </shape>
    </item>
</layer-list>