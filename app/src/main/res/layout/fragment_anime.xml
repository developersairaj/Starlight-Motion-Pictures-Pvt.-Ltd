<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050810">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0A0E1A"
        android:elevation="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- Brand row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANIME &amp; MANGA"
                    android:textColor="#E8C547"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Powered by MyAnimeList"
                    android:textColor="#2A3050"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAL"
                android:textColor="#E8C547"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_genre"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"/>

        </LinearLayout>

        <!-- Search bar with camera button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_cosmos"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:paddingStart="14dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                android:alpha="0.4"/>

            <EditText
                android:id="@+id/etAnimeSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search anime or manga..."
                android:textColor="#F0F4FF"
                android:textColorHint="#252D45"
                android:textSize="13sp"
                android:paddingStart="10dp"
                android:paddingEnd="6dp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:autofillHints="no"
                android:singleLine="true"/>

            <!-- Camera button for image search -->
            <ImageButton
                android:id="@+id/btnAnimeImageSearch"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_camera"
                android:contentDescription="Search by image"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#E8C547"/>

            <!-- Clear button -->
            <ImageButton
                android:id="@+id/btnAnimeClear"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Clear"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Sub-tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <Button
                android:id="@+id/btnAnimeTab1"
                style="@style/TabBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Top"/>

            <Button
                android:id="@+id/btnAnimeTab2"
                style="@style/TabBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Airing"/>

            <Button
                android:id="@+id/btnAnimeTab3"
                style="@style/TabBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Upcoming"/>

            <Button
                android:id="@+id/btnAnimeTab4"
                style="@style/TabBtn"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:text="Manga"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshAnime"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAnime"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="6dp"
                android:clipToPadding="false"
                android:scrollbars="none"/>

            <LinearLayout
                android:id="@+id/layoutAnimeEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="( ^_^ )"
                    android:textColor="#E8C547"
                    android:textSize="36sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading anime..."
                    android:textColor="#2A3050"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>