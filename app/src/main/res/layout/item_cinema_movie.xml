<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="14dp"
    app:cardBackgroundColor="#0D0C1E"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Poster -->
        <ImageView
            android:id="@+id/ivCinemaPoster"
            android:layout_width="90dp"
            android:layout_height="130dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_card_glass"
            android:contentDescription="Movie poster"/>

        <!-- Right column: title, meta, overview, button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tvCinemaTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="5dp"/>

            <!-- Rating + Year + Lang -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvCinemaRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFB700"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvCinemaYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#504870"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tvCinemaLang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#00F5FF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:background="@drawable/bg_badge_type"/>

            </LinearLayout>

            <!-- Overview -->
            <TextView
                android:id="@+id/tvCinemaOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#6A5F80"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="3"
                android:ellipsize="end"
                android:layout_marginBottom="10dp"/>

            <!-- Book Tickets button -->
            <LinearLayout
                android:id="@+id/btnBookTickets"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/bg_btn_gold"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Book Tickets on BMS"
                    android:textColor="#000000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>