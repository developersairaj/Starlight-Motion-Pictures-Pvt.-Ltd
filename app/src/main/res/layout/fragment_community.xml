<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_cosmos">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header"
        android:elevation="16dp"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE CHAT"
                    android:textColor="#80FFB700"
                    android:textSize="8sp"
                    android:letterSpacing="0.25"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMMUNITY"
                    android:textColor="#FFB700"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvRoomName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Movies Room"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 messages"
                    android:textColor="#504870"
                    android:textSize="10sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Room selector tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnRoomMovies"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Movies"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_btn_gold"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRoomSeries"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Series"
                    android:textSize="11sp"
                    android:textColor="#C0B8E0"
                    android:background="@drawable/bg_badge_genre"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRoomDrama"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Drama"
                    android:textSize="11sp"
                    android:textColor="#C0B8E0"
                    android:background="@drawable/bg_badge_genre"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRoomKdrama"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="K-Drama"
                    android:textSize="11sp"
                    android:textColor="#C0B8E0"
                    android:background="@drawable/bg_badge_genre"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRoomCdrama"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="C-Drama"
                    android:textSize="11sp"
                    android:textColor="#C0B8E0"
                    android:background="@drawable/bg_badge_genre"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRoomAnime"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Anime"
                    android:textSize="11sp"
                    android:textColor="#C0B8E0"
                    android:background="@drawable/bg_badge_genre"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btnRoomCartoons"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Cartoons"
                    android:textSize="11sp"
                    android:textColor="#C0B8E0"
                    android:background="@drawable/bg_badge_genre"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>

            </LinearLayout>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Messages list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="never"/>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header"
        android:elevation="16dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <!-- Avatar circle -->
        <TextView
            android:id="@+id/tvInputAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="?"
            android:textColor="#FFB700"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_avatar_circle"
            android:layout_marginEnd="10dp"/>

        <!-- Text input -->
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_badge_genre"
            android:hint="Say something..."
            android:textColor="#FFFFFF"
            android:textColorHint="#504870"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:singleLine="true"
            android:layout_marginEnd="10dp"/>

        <!-- Send button -->
        <LinearLayout
            android:id="@+id/btnSend"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:background="@drawable/bg_btn_gold"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&gt;"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>